    <!-- 文件夹 -->
    <item name="ic_folder" type="drawable">@drawable/folder</item>
    <!-- 构建：锤子 -->
    <item name="folder_build" type="drawable">@drawable/ic_build</item>
    <!-- 资源箱 -->
    <item name="folder_assets" type="drawable">@drawable/ic_inventory</item>
