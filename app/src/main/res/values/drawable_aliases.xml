    <item name="file" type="drawable">@drawable/file_text</item>
    <!-- 代码 / XML 共用 <> -->
    <item name="file_xml" type="drawable">@drawable/file_code</item>
    <item name="ic_code" type="drawable">@drawable/file_code</item>
