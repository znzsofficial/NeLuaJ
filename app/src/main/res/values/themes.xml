<resources>
    <!-- 色盘走 Material 父主题默认；仅统一状态栏/导航栏 -->
    <style name="Theme.NeLuaJ.Material3" parent="Theme.Material3Expressive.DayNight">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.NeLuaJ.Material3.ActionOverlay" parent="Theme.NeLuaJ.Material3">
        <item name="windowActionModeOverlay">true</item>
    </style>

    <!-- 状态栏/导航栏跟 surface，避免 Material 父主题落到 colorPrimary -->
    <style name="Theme.NeLuaJ.Material3.NoActionBar" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.NeLuaJ.Material3.NoActionBar.ActionOverlay" parent="Theme.NeLuaJ.Material3.NoActionBar">
        <item name="windowActionModeOverlay">true</item>
    </style>

    <style name="Theme.NeLuaJ.Material3.DynamicColors" parent="@style/Theme.Material3Expressive.DynamicColors.DayNight">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.NeLuaJ.Material3.DynamicColors.ActionOverlay" parent="Theme.NeLuaJ.Material3.DynamicColors">
        <item name="windowActionModeOverlay">true</item>
    </style>

    <style name="Theme.NeLuaJ.Material3.DynamicColors.NoActionBar" parent="@style/Theme.Material3Expressive.DynamicColors.DayNight.NoActionBar">
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.NeLuaJ.Material3.DynamicColors.NoActionBar.ActionOverlay" parent="Theme.NeLuaJ.Material3.DynamicColors.NoActionBar">
        <item name="windowActionModeOverlay">true</item>
    </style>

    <style name="ThemeOverlay.Catalog.SideSheet.Modal.Detached" parent="@style/ThemeOverlay.Material3.SideSheetDialog">
        <item name="sideSheetModalStyle">@style/Widget.Material3.SideSheet.Modal.Detached</item>
    </style>

    <style name="Theme.NeLuaJ.Compat" parent="Theme.AppCompat.DayNight" />

    <style name="Theme.NeLuaJ.Compat.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <style name="WelcomeTheme" parent="Theme.NeLuaJ.Material3">
        <item name="windowActionModeOverlay">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:statusBarColor">?colorSurface</item>
        <item name="android:navigationBarColor">?colorSurface</item>
        <item name="android:windowBackground">@drawable/welcome</item>
    </style>

    <!-- MC：勿用 DarkActionBar（浅色模式会强制深色栏/状态栏） -->
    <style name="Theme.NeLuaJ.MaterialComponent" parent="@style/Theme.MaterialComponents.DayNight" />

    <style name="Theme.NeLuaJ.MaterialComponent.NoActionBar" parent="@style/Theme.MaterialComponents.DayNight.NoActionBar" />

    <style name="Theme.NeLuaJ.MaterialComponent.Dark" parent="@style/Theme.MaterialComponents" />

    <style name="Theme.NeLuaJ.MaterialComponent.Dark.NoActionBar" parent="@style/Theme.MaterialComponents.NoActionBar" />

    <style name="Theme.NeLuaJ.MaterialComponent.Light" parent="@style/Theme.MaterialComponents.Light" />

    <style name="Theme.NeLuaJ.MaterialComponent.Light.NoActionBar" parent="@style/Theme.MaterialComponents.Light.NoActionBar" />
</resources>
